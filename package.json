{
  "name": "zeroone",
  "version": "1.1.5",
  "private": true,
  "description": "ZeroOne, CRM de escritorio para gestionar estados y contactos de WhatsApp",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test:internal": "node --test --test-isolation=none tests/internal-safety.test.js tests/emergency-stop.test.js tests/publication-guard.test.js tests/reconnection-circuit-breaker.test.js tests/session-security.test.js tests/session-backup-manager.test.js tests/startup-sync-coordinator.test.js tests/encrypted-auth-state.test.js tests/auth-startup-guard.test.js tests/image-compression.test.js tests/agendamiento.test.js tests/history-sync-queue.test.js tests/ai-username-detector.test.js tests/local-ai-runtime.test.js tests/recent-message-store.test.js",
    "build:icon": "node scripts/build-icon.js",
    "prebuild": "npm run build:icon",
    "build": "electron-builder --win --x64",
    "prebuild:signed": "npm run build:icon",
    "build:signed": "electron-builder --win --x64 --config.win.forceCodeSigning=true",
    "prerelease": "npm run build:icon",
    "release": "electron-builder --win --x64 --publish always --config.win.forceCodeSigning=true"
  },
  "keywords": [
    "electron",
    "whatsapp",
    "estados"
  ],
  "author": "ZABO",
  "copyright": "Copyright © 2026 ZABO",
  "license": "ISC",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "node-schedule": "^2.1.1",
    "pino": "^9.2.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.zabo.autostatues",
    "productName": "ZeroOne",
    "executableName": "ZeroOne",
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "THIRD_PARTY_NOTICES.txt",
      "src/**/*",
      "public/**/*",
      "font/**/*",
      "package.json",
      "!dist/**/*",
      "!sesiones/**/*",
      "!uploads/**/*",
      "!programados/**/*",
      "!**/*.log"
    ],
    "win": {
      "icon": "build/icon.ico",
      "verifyUpdateCodeSignature": true,
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      },
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ZeroOne-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZeroOne",
      "uninstallDisplayName": "ZeroOne ${version}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Ztrash-apps",
        "repo": "AutoStatues"
      }
    ]
  }
}
